<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Bug Report Platform{% endblock %}</title>
        <link rel="icon" href="data:,">
        {% block stylesheets %}
            <style>
                :root {
                    color-scheme: light;
                    --bg: #f4f6f8;
                    --panel: #ffffff;
                    --text: #18202f;
                    --muted: #657084;
                    --line: #d7deea;
                    --accent: #1f5fe0;
                    --accent-strong: #1746a2;
                    --danger: #b42318;
                    --shadow: 0 10px 28px rgba(15, 23, 42, 0.06);
                    --shadow-soft: 0 2px 8px rgba(15, 23, 42, 0.04);
                }

                * {
                    box-sizing: border-box;
                }

                body {
                    margin: 0;
                    background: var(--bg);
                    color: var(--text);
                    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
                    line-height: 1.5;
                }

                a {
                    color: var(--accent);
                    text-decoration: none;
                }

                .topbar {
                    align-items: center;
                    background: var(--panel);
                    border-bottom: 1px solid var(--line);
                    box-shadow: var(--shadow-soft);
                    display: flex;
                    gap: 1rem;
                    justify-content: space-between;
                    padding: .85rem 1.25rem;
                    position: sticky;
                    top: 0;
                    z-index: 20;
                }

                .brand {
                    color: var(--text);
                    display: inline-flex;
                    font-weight: 800;
                    letter-spacing: 0;
                }

                .nav {
                    align-items: center;
                    display: flex;
                    flex-wrap: wrap;
                    gap: .75rem;
                }

                .nav a {
                    border-radius: 8px;
                    color: var(--text);
                    padding: .35rem .65rem;
                    transition: background-color .15s ease, color .15s ease;
                }

                .nav a:hover {
                    background: #edf3ff;
                    color: var(--accent);
                }

                .container {
                    margin: 0 auto;
                    max-width: none;
                    padding: 1.5rem clamp(1rem, 2vw, 2rem) 2.5rem;
                    width: 100%;
                }

                .panel,
                .metric {
                    background: var(--panel);
                    border: 1px solid var(--line);
                    border-radius: 12px;
                    box-shadow: var(--shadow-soft);
                    padding: 1.25rem;
                }

                .metric {
                    padding: 1rem;
                }

                .grid {
                    display: grid;
                    gap: 1rem;
                    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
                }

                .metric strong {
                    display: block;
                    font-size: 1.5rem;
                    line-height: 1;
                    margin-top: .4rem;
                }

                .muted {
                    color: var(--muted);
                }

                .form {
                    display: grid;
                    gap: .9rem;
                }

                .form input,
                .form textarea,
                .form select {
                    border: 1px solid var(--line);
                    border-radius: 8px;
                    font: inherit;
                    padding: .72rem .85rem;
                    width: 100%;
                }

                .form textarea {
                    min-height: 8rem;
                    resize: vertical;
                }

                .form input:focus,
                .form textarea:focus,
                .form select:focus,
                .filters input:focus,
                .filters select:focus {
                    border-color: rgba(31, 95, 224, .45);
                    box-shadow: 0 0 0 2px rgba(31, 95, 224, .12);
                    outline: none;
                }

                .form-inline {
                    align-items: end;
                    grid-template-columns: minmax(180px, 280px) auto;
                }

                .page-header {
                    align-items: center;
                    display: flex;
                    gap: 1rem;
                    justify-content: space-between;
                    margin-bottom: .9rem;
                }

                .page-header h1 {
                    margin: 0;
                    font-size: 1.45rem;
                    letter-spacing: 0;
                }

                .stack {
                    display: grid;
                    gap: 1rem;
                }

                .auth-shell {
                    display: grid;
                    min-height: calc(100vh - 120px);
                    place-items: center;
                    padding: 1.5rem 0 3rem;
                }

                .auth-panel {
                    background: var(--panel);
                    border: 1px solid var(--line);
                    border-radius: 14px;
                    box-shadow: var(--shadow);
                    max-width: 460px;
                    padding: 1.5rem;
                    width: 100%;
                }

                .auth-mark {
                    align-items: center;
                    color: var(--muted);
                    display: inline-flex;
                    font-size: .85rem;
                    font-weight: 700;
                    gap: .5rem;
                    letter-spacing: 0;
                    text-transform: uppercase;
                }

                .auth-dot {
                    background: var(--accent);
                    border-radius: 999px;
                    box-shadow: 0 0 0 4px rgba(31, 95, 224, 0.1);
                    display: inline-block;
                    height: .7rem;
                    width: .7rem;
                }

                .auth-panel h1 {
                    font-size: 1.75rem;
                    letter-spacing: 0;
                    margin: .5rem 0 .25rem;
                }

                .auth-form {
                    margin-top: 1rem;
                }

                .auth-button {
                    margin-top: .25rem;
                    width: 100%;
                }

                .table-wrap {
                    overflow-x: auto;
                }

                table {
                    border-collapse: collapse;
                    width: 100%;
                }

                th,
                td {
                    border-bottom: 1px solid var(--line);
                    padding: .75rem;
                    text-align: left;
                    vertical-align: top;
                }

                th {
                    color: var(--muted);
                    font-size: .9rem;
                    font-weight: 700;
                    letter-spacing: .01em;
                }

                tbody tr:nth-child(even) {
                    background: #f9fbff;
                }

                tbody tr:hover {
                    background: #f2f7ff;
                }

                .badge {
                    border-radius: 999px;
                    display: inline-flex;
                    font-size: .82rem;
                    font-weight: 700;
                    line-height: 1;
                    padding: .3rem .55rem;
                    white-space: nowrap;
                }

                .badge-priority-low,
                .badge-status-fixed,
                .badge-status-closed {
                    background: #ecfdf3;
                    color: #027a48;
                }

                .badge-priority-medium,
                .badge-status-open {
                    background: #eff6ff;
                    color: #175cd3;
                }

                .badge-priority-high,
                .badge-status-in_progress {
                    background: #fffaeb;
                    color: #b54708;
                }

                .badge-priority-critical,
                .badge-status-rejected {
                    background: #fef3f2;
                    color: #b42318;
                }

                .meta-list {
                    display: grid;
                    gap: .75rem;
                    margin: 0;
                }

                .meta-list div {
                    display: grid;
                    gap: .25rem;
                }

                .meta-list dt {
                    color: var(--muted);
                    font-weight: 700;
                }

                .meta-list dd {
                    margin: 0;
                }

                .comments {
                    display: grid;
                    gap: .75rem;
                }

                .comment {
                    border: 1px solid var(--line);
                    border-radius: 12px;
                    box-shadow: var(--shadow-soft);
                    padding: 1rem;
                    background: var(--panel);
                }

                .comment header {
                    align-items: center;
                    display: flex;
                    flex-wrap: wrap;
                    gap: .5rem;
                    justify-content: space-between;
                }

                .screenshot-preview {
                    border: 1px solid var(--line);
                    border-radius: 12px;
                    box-shadow: var(--shadow-soft);
                    display: block;
                    height: auto;
                    max-width: min(100%, 760px);
                }

                .button {
                    background: var(--accent);
                    border: 0;
                    border-radius: 8px;
                    color: #fff;
                    cursor: pointer;
                    display: inline-flex;
                    font: inherit;
                    font-weight: 700;
                    justify-content: center;
                    padding: .7rem .95rem;
                    transition: background-color .15s ease, transform .15s ease, box-shadow .15s ease;
                    box-shadow: none;
                }

                .button:hover {
                    background: var(--accent-strong);
                    transform: translateY(-1px);
                }

                .button-secondary {
                    background: #eef2f7;
                    color: var(--text);
                }

                .button-secondary:hover {
                    background: #e2e8f0;
                }

                .button-danger {
                    background: var(--danger);
                    color: #fff;
                }

                .button-danger:hover {
                    background: #9f1d14;
                }

                .actions {
                    align-items: center;
                    display: flex;
                    flex-wrap: wrap;
                    gap: .6rem;
                }

                .filters {
                    display: grid;
                    gap: .9rem;
                    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
                }

                .filters input,
                .filters select {
                    border: 1px solid var(--line);
                    border-radius: 6px;
                    font: inherit;
                    padding: .65rem .75rem;
                    width: 100%;
                }

                .filter-actions {
                    align-items: end;
                    display: flex;
                    gap: .6rem;
                }

                .dashboard-grid {
                    display: grid;
                    gap: 1rem;
                    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
                    margin-top: 1rem;
                }

                .quick-actions {
                    display: grid;
                    gap: .75rem;
                    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
                    margin-bottom: 1rem;
                }

                .quick-action {
                    background: var(--panel);
                    border: 1px solid var(--line);
                    border-radius: 12px;
                    box-shadow: var(--shadow-soft);
                    color: var(--text);
                    display: grid;
                    gap: .3rem;
                    padding: 1rem;
                    transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
                }

                .quick-action strong {
                    color: var(--accent);
                }

                .quick-action:hover {
                    border-color: rgba(31, 95, 224, .25);
                    box-shadow: var(--shadow-soft);
                    transform: translateY(-1px);
                }

                .alert {
                    border-radius: 10px;
                    padding: .75rem .9rem;
                }

                .alert-danger {
                    background: #fef3f2;
                    color: var(--danger);
                }

                .alert-success {
                    background: #ecfdf3;
                    color: #027a48;
                }

                @media (max-width: 640px) {
                    .topbar {
                        align-items: flex-start;
                        flex-direction: column;
                    }

                    .page-header {
                        align-items: flex-start;
                        flex-direction: column;
                    }

                    .actions,
                    .filter-actions {
                        width: 100%;
                    }

                    .form-inline {
                        grid-template-columns: 1fr;
                    }

                    .auth-panel {
                        border-radius: 12px;
                        padding: 1.25rem;
                    }
                }
            </style>
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <header class="topbar">
            <a class="brand" href="{{ path('app_home') }}">Bug Report Platform</a>
            <nav class="nav">
                {% if app.user %}
                    {% set actualRoles = app.user.roles %}
                    {% if 'ROLE_ADMIN' in actualRoles %}
                        <a href="{{ path('admin_dashboard') }}">Dashboard</a>
                    {% elseif 'ROLE_DEVELOPER' in actualRoles %}
                        <a href="{{ path('developer_dashboard') }}">Dashboard</a>
                    {% elseif 'ROLE_CLIENT' in actualRoles %}
                        <a href="{{ path('client_dashboard') }}">Dashboard</a>
                    {% endif %}
                    <a href="{{ path('app_bug_report_index') }}">Bugs</a>
                    {% if 'ROLE_CLIENT' in actualRoles or 'ROLE_ADMIN' in actualRoles %}
                        <a href="{{ path('app_bug_report_new') }}">New Bug</a>
                    {% endif %}
                    {% if 'ROLE_ADMIN' in actualRoles %}
                        <a href="{{ path('app_admin_project_index') }}">Projects</a>
                        <a href="{{ path('app_admin_project_new') }}">New Project</a>
                        <a href="{{ path('app_admin_user_index') }}">Users</a>
                    {% endif %}
                    <span class="muted">{{ app.user.fullName }}</span>
                    <a href="{{ path('app_logout') }}">Logout</a>
                {% endif %}
            </nav>
        </header>
        <main class="container">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
