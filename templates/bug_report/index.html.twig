{% extends 'base.html.twig' %}

{% block title %}Bug Reports | Bug Report Platform{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>Bug Reports</h1>
            <p class="muted">Track reported bugs and their current status.</p>
        </div>

        {% if is_granted('ROLE_CLIENT') %}
            <a class="button" href="{{ path('app_bug_report_new') }}">New Bug Report</a>
        {% endif %}
    </div>

    <section class="panel">
        {% if bug_reports is empty %}
            <p class="muted">No bug reports found.</p>
        {% else %}
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Project</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Reporter</th>
                            <th>Developer</th>
                            <th>Created</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for bug_report in bug_reports %}
                            <tr>
                                <td>{{ bug_report.title }}</td>
                                <td>{{ bug_report.project.name }}</td>
                                <td>{{ bug_report.priority.label() }}</td>
                                <td>{{ bug_report.status.label() }}</td>
                                <td>{{ bug_report.reporter.fullName }}</td>
                                <td>{{ bug_report.assignedDeveloper ? bug_report.assignedDeveloper.fullName : 'Unassigned' }}</td>
                                <td>{{ bug_report.createdAt|date('Y-m-d H:i') }}</td>
                                <td><a href="{{ path('app_bug_report_show', {'id': bug_report.id}) }}">View</a></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
{% endblock %}
