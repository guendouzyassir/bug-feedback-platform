{% extends 'base.html.twig' %}

{% block title %}{{ bug_report.title }} | Bug Report Platform{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>{{ bug_report.title }}</h1>
            <p class="muted">#{{ bug_report.id }} · {{ bug_report.project.name }} · {{ bug_report.createdAt|date('Y-m-d H:i') }}</p>
        </div>
        <a href="{{ path('app_bug_report_index') }}">Back to bugs</a>
    </div>

    <section class="grid">
        <article class="metric">
            Priority
            <strong><span class="badge badge-priority-{{ bug_report.priority.value }}">{{ bug_report.priority.label() }}</span></strong>
        </article>
        <article class="metric">
            Status
            <strong><span class="badge badge-status-{{ bug_report.status.value }}">{{ bug_report.status.label() }}</span></strong>
        </article>
        <article class="metric">
            Reporter
            <strong>{{ bug_report.reporter.fullName }}</strong>
        </article>
        <article class="metric">
            Developer
            <strong>{{ bug_report.assignedDeveloper ? bug_report.assignedDeveloper.fullName : 'Unassigned' }}</strong>
        </article>
    </section>

    <section class="panel stack">
        <div>
            <h2>Description</h2>
            <p>{{ bug_report.description|nl2br }}</p>
        </div>

        {% if bug_report.stepsToReproduce %}
            <div>
                <h2>Steps to Reproduce</h2>
                <p>{{ bug_report.stepsToReproduce|nl2br }}</p>
            </div>
        {% endif %}

        {% if bug_report.expectedResult %}
            <div>
                <h2>Expected Result</h2>
                <p>{{ bug_report.expectedResult|nl2br }}</p>
            </div>
        {% endif %}

        {% if bug_report.actualResult %}
            <div>
                <h2>Actual Result</h2>
                <p>{{ bug_report.actualResult|nl2br }}</p>
            </div>
        {% endif %}

        {% if bug_report.screenshotFilename %}
            <div>
                <h2>Screenshot</h2>
                <a href="{{ path('app_bug_report_screenshot', {'id': bug_report.id}) }}" target="_blank" rel="noopener">
                    <img class="screenshot-preview" src="{{ path('app_bug_report_screenshot', {'id': bug_report.id}) }}" alt="Screenshot for {{ bug_report.title }}">
                </a>
            </div>
        {% endif %}
    </section>

    <section class="panel stack">
        <h2>Timeline</h2>
        <dl class="meta-list">
            <div>
                <dt>Created</dt>
                <dd>{{ bug_report.createdAt|date('Y-m-d H:i') }}</dd>
            </div>
            <div>
                <dt>Last Updated</dt>
                <dd>{{ bug_report.updatedAt|date('Y-m-d H:i') }}</dd>
            </div>
            {% if bug_report.closedAt %}
                <div>
                    <dt>Closed</dt>
                    <dd>{{ bug_report.closedAt|date('Y-m-d H:i') }}</dd>
                </div>
            {% endif %}
        </dl>
    </section>

    <section class="panel stack">
        <h2>Comments</h2>

        {{ form_start(comment_form, {'attr': {'class': 'form'}}) }}
            {{ form_row(comment_form.content) }}
            <button class="button">Add Comment</button>
        {{ form_end(comment_form) }}

        {% if bug_report.comments is empty %}
            <p class="muted">No comments yet.</p>
        {% else %}
            <div class="comments">
                {% for comment in bug_report.comments %}
                    <article class="comment">
                        <header>
                            <strong>{{ comment.author.fullName }}</strong>
                            <span class="muted">{{ comment.createdAt|date('Y-m-d H:i') }}</span>
                        </header>
                        <p>{{ comment.content|nl2br }}</p>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </section>
{% endblock %}
