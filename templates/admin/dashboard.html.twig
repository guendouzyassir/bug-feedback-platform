{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard | Bug Report Platform{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>Admin Dashboard</h1>
            <p class="muted">Project, bug, and workflow overview.</p>
        </div>
        <div class="actions">
            <a class="button" href="{{ path('app_bug_report_index') }}">View Bugs</a>
            <a class="button button-secondary" href="{{ path('app_admin_project_index') }}">Projects</a>
            <a class="button button-secondary" href="{{ path('app_admin_user_index') }}">Users</a>
        </div>
    </div>

    <section class="quick-actions">
        <a class="quick-action" href="{{ path('app_admin_project_new') }}">
            <strong>New Project</strong>
            <span class="muted">Add a web, mobile, or API project.</span>
        </a>
        <a class="quick-action" href="{{ path('app_admin_project_index') }}">
            <strong>Manage Projects</strong>
            <span class="muted">Edit project details and status.</span>
        </a>
        <a class="quick-action" href="{{ path('app_bug_report_index') }}">
            <strong>Manage Bugs</strong>
            <span class="muted">Assign developers and update status.</span>
        </a>
        <a class="quick-action" href="{{ path('app_bug_report_new') }}">
            <strong>New Bug Report</strong>
            <span class="muted">Create a report during testing.</span>
        </a>
        <a class="quick-action" href="{{ path('app_admin_user_new') }}">
            <strong>New User</strong>
            <span class="muted">Create employee or client accounts.</span>
        </a>
        <a class="quick-action" href="{{ path('app_admin_user_index') }}">
            <strong>Manage Users</strong>
            <span class="muted">Edit roles, status, and passwords.</span>
        </a>
    </section>

    <section class="grid">
        <article class="metric">
            Users
            <strong>{{ userCount }}</strong>
        </article>
        <article class="metric">
            Projects
            <strong>{{ projectCount }}</strong>
        </article>
        <article class="metric">
            Bug Reports
            <strong>{{ bugCount }}</strong>
        </article>
        <article class="metric">
            Open
            <strong>{{ openBugCount }}</strong>
        </article>
        <article class="metric">
            In Progress
            <strong>{{ inProgressBugCount }}</strong>
        </article>
        <article class="metric">
            Fixed
            <strong>{{ fixedBugCount }}</strong>
        </article>
        <article class="metric">
            Critical
            <strong>{{ criticalBugCount }}</strong>
        </article>
        <article class="metric">
            Unassigned
            <strong>{{ unassignedBugCount }}</strong>
        </article>
    </section>

    <section class="dashboard-grid">
        <article class="panel stack">
            <h2>Bugs By Status</h2>
            <table>
                <tbody>
                    {% for item in bugsByStatus %}
                        <tr>
                            <td>{{ item.label }}</td>
                            <td><strong>{{ item.count }}</strong></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </article>

        <article class="panel stack">
            <h2>Bugs By Project</h2>
            {% if bugsByProject is empty %}
                <p class="muted">No bugs have been reported yet.</p>
            {% else %}
                <table>
                    <tbody>
                        {% for item in bugsByProject %}
                            <tr>
                                <td>{{ item.name }}</td>
                                <td><strong>{{ item.count }}</strong></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </article>
    </section>
{% endblock %}
