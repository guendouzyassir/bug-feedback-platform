{% extends 'base.html.twig' %}

{% block title %}Projects | Bug Report Platform{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>Projects</h1>
            <p class="muted">Manage the web and mobile applications that can receive bug reports.</p>
        </div>
        <div class="actions">
            <a class="button" href="{{ path('app_admin_project_new') }}">New Project</a>
            <a class="button button-secondary" href="{{ path('admin_dashboard') }}">Dashboard</a>
            <a class="button button-secondary" href="{{ path('app_bug_report_index') }}">Bugs</a>
        </div>
    </div>

    <section class="panel">
        {% if projects is empty %}
            <p class="muted">No projects have been created yet.</p>
        {% else %}
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Platform</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Updated</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for project in projects %}
                            <tr>
                                <td>
                                    <a href="{{ path('app_admin_project_show', {'id': project.id}) }}">{{ project.name }}</a>
                                    {% if project.description %}
                                        <div class="muted">{{ project.description }}</div>
                                    {% endif %}
                                </td>
                                <td>{{ project.platform }}</td>
                                <td>{{ project.isActive ? 'Active' : 'Inactive' }}</td>
                                <td>{{ project.createdAt|date('Y-m-d H:i') }}</td>
                                <td>{{ project.updatedAt|date('Y-m-d H:i') }}</td>
                                <td>
                                    <div class="actions">
                                        <a href="{{ path('app_admin_project_show', {'id': project.id}) }}">View</a>
                                        <a href="{{ path('app_admin_project_edit', {'id': project.id}) }}">Edit</a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
{% endblock %}
