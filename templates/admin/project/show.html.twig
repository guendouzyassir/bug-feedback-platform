{% extends 'base.html.twig' %}

{% block title %}{{ project.name }} | Bug Report Platform{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>{{ project.name }}</h1>
            <p class="muted">{{ project.platform }} project</p>
        </div>
        <div class="actions">
            <a class="button" href="{{ path('app_admin_project_edit', {'id': project.id}) }}">Edit</a>
            <a class="button button-secondary" href="{{ path('app_admin_project_index') }}">Back to Projects</a>
        </div>
    </div>

    <section class="panel stack">
        <dl class="meta-list">
            <div>
                <dt>Description</dt>
                <dd>{{ project.description ?: 'No description provided.' }}</dd>
            </div>
            <div>
                <dt>Status</dt>
                <dd>{{ project.isActive ? 'Active' : 'Inactive' }}</dd>
            </div>
            <div>
                <dt>Created</dt>
                <dd>{{ project.createdAt|date('Y-m-d H:i') }}</dd>
            </div>
            <div>
                <dt>Last Updated</dt>
                <dd>{{ project.updatedAt|date('Y-m-d H:i') }}</dd>
            </div>
        </dl>

        {{ include('admin/project/_delete_form.html.twig') }}
    </section>
{% endblock %}
