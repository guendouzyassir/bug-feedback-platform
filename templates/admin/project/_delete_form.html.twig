<form method="post" action="{{ path('app_admin_project_delete', {'id': project.id}) }}" onsubmit="return confirm('Delete this project? Existing bug reports for this project may also be removed.');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ project.id) }}">
    <button class="button button-danger">Delete Project</button>
</form>
