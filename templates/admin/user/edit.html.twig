{% extends 'base.html.twig' %}

{% block title %}Edit {{ user.fullName }} | Bug Report Platform{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>Edit User</h1>
            <p class="muted">{{ user.fullName }} · {{ user.email }}</p>
        </div>
        <a class="button button-secondary" href="{{ path('app_admin_user_index') }}">Back to Users</a>
    </div>

    <section class="panel">
        {{ include('admin/user/_form.html.twig', {'button_label': 'Update User'}) }}
    </section>
{% endblock %}
