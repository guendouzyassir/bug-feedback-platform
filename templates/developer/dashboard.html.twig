{% extends 'base.html.twig' %}

{% block title %}Developer Dashboard | Bug Report Platform{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>Developer Dashboard</h1>
            <p class="muted">Review assigned work and update bug status.</p>
        </div>
        <a class="button" href="{{ path('app_bug_report_index') }}">View Bugs</a>
    </div>

    <section class="grid">
        <article class="metric">
            Assigned Bugs
            <strong>{{ assignedBugCount }}</strong>
        </article>
    </section>

    <section class="quick-actions">
        <a class="quick-action" href="{{ path('app_bug_report_index', {'developer': app.user.id}) }}">
            <strong>My Assigned Bugs</strong>
            <span class="muted">Review bugs assigned to you.</span>
        </a>
        <a class="quick-action" href="{{ path('app_bug_report_index', {'status': 'open'}) }}">
            <strong>Open Bugs</strong>
            <span class="muted">Check bugs that still need triage.</span>
        </a>
        <a class="quick-action" href="{{ path('app_bug_report_index', {'status': 'in_progress'}) }}">
            <strong>In Progress</strong>
            <span class="muted">Continue active development work.</span>
        </a>
    </section>
{% endblock %}
