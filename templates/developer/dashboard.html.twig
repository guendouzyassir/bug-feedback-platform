{% extends 'base.html.twig' %}

{% block title %}Developer Dashboard | Bug Report Platform{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>Developer Dashboard</h1>
            <p class="muted">Review assigned work and update bug status.</p>
        </div>
        <a class="button" href="{{ path('app_bug_report_index') }}">View Bugs</a>
    </div>

    <section class="grid">
        <article class="metric">
            Assigned Bugs
            <strong>{{ assignedBugCount }}</strong>
        </article>
    </section>
{% endblock %}
