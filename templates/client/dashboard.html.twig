{% extends 'base.html.twig' %}

{% block title %}Client Dashboard | Bug Report Platform{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>Client Dashboard</h1>
            <p class="muted">Create bug reports and follow your submitted issues.</p>
        </div>
        <a class="button" href="{{ path('app_bug_report_new') }}">New Bug Report</a>
    </div>

    <section class="grid">
        <article class="metric">
            Reported Bugs
            <strong>{{ reportedBugCount }}</strong>
        </article>
    </section>

    <section class="quick-actions">
        <a class="quick-action" href="{{ path('app_bug_report_new') }}">
            <strong>Report New Bug</strong>
            <span class="muted">Send details, priority, and screenshot.</span>
        </a>
        <a class="quick-action" href="{{ path('app_bug_report_index') }}">
            <strong>My Bug Reports</strong>
            <span class="muted">Follow status and developer comments.</span>
        </a>
    </section>
{% endblock %}
